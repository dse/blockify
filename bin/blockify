#!/usr/bin/perl
use utf8;
use warnings;
use strict;
use open IO => ":utf8";
use Text::Tabs qw(expand);
use List::Util qw(max);

binmode(STDIN, ":utf8");
binmode(STDOUT, ":utf8");
binmode(STDERR, ":utf8");

our $half_height;
our $half_width;
our $ascii;

use Getopt::Long;
Getopt::Long::Configure(qw(gnu_getopt));
Getopt::Long::GetOptions(
    "h|half|half-height" => \$half_height,
    "w|half-width" => \$half_width,
    "a|ascii" => \$ascii,
);

if ($ascii && $half_width) {
    die("-a/--ascii and -w/--half-width are mutually exclusive.\n");
}

our $RX_SPACE      = qr{\s};
our $RX_UPPER_HALF = qr{['"`▀]};
our $RX_LOWER_HALF = qr{[,.▄]};
our $RX_FULL       = qr{[^\s'"`,.▀▄]};

our @HALF_WIDTH_HALF_HEIGHT = (
    qr{\s\s\s\s} => " ",
    qr{\s\s\s\S} => "▗",
    qr{\s\s\S\s} => "▖",
    qr{\s\s\S\S} => "▄",
    qr{\s\S\s\s} => "▝",
    qr{\s\S\s\S} => "▐",
    qr{\s\S\S\s} => "▞",
    qr{\s\S\S\S} => "▟",
    qr{\S\s\s\s} => "▘",
    qr{\S\s\s\S} => "▚",
    qr{\S\s\S\s} => "▌",
    qr{\S\s\S\S} => "▙",
    qr{\S\S\s\s} => "▀",
    qr{\S\S\s\S} => "▜",
    qr{\S\S\S\s} => "▛",
    qr{\S\S\S\S} => "█",
);

our @HALF_WIDTH = (
    qr{ ${RX_SPACE}      ${RX_SPACE}      }x => " ",
    qr{ ${RX_SPACE}      ${RX_LOWER_HALF} }x => "▗",
    qr{ ${RX_LOWER_HALF} ${RX_SPACE}      }x => "▖",
    qr{ ${RX_LOWER_HALF} ${RX_LOWER_HALF} }x => "▄",
    qr{ ${RX_SPACE}      ${RX_UPPER_HALF} }x => "▝",
    qr{ ${RX_SPACE}      ${RX_FULL}       }x => "▐",
    qr{ ${RX_LOWER_HALF} ${RX_UPPER_HALF} }x => "▞",
    qr{ ${RX_LOWER_HALF} ${RX_FULL}       }x => "▟",
    qr{ ${RX_UPPER_HALF} ${RX_SPACE}      }x => "▘",
    qr{ ${RX_UPPER_HALF} ${RX_LOWER_HALF} }x => "▚",
    qr{ ${RX_FULL}       ${RX_SPACE}      }x => "▌",
    qr{ ${RX_FULL}       ${RX_LOWER_HALF} }x => "▙",
    qr{ ${RX_UPPER_HALF} ${RX_UPPER_HALF} }x => "▀",
    qr{ ${RX_UPPER_HALF} ${RX_FULL}       }x => "▜",
    qr{ ${RX_FULL}       ${RX_UPPER_HALF} }x => "▛",
    qr{ ${RX_FULL}       ${RX_FULL}       }x => "█",
);

our @ASCII_HALF_HEIGHT = (
    qr{\s\s} => " ",
    qr{\S\s} => "'",
    qr{\s\S} => ".",
    qr{\S\S} => ":",
);

our @HALF_HEIGHT = (
    qr{\s\s} => " ",
    qr{\S\s} => "▀",
    qr{\s\S} => "▄",
    qr{\S\S} => "█",
);

our @ASCII_FULL_SIZE = (
    $RX_SPACE      => " ",
    $RX_UPPER_HALF => "'",
    $RX_LOWER_HALF => ".",
    $RX_FULL       => ":",
);

our @FULL_SIZE = (
    $RX_SPACE      => " ",
    $RX_UPPER_HALF => "▀",
    $RX_LOWER_HALF => "▄",
    $RX_FULL       => "█",
);

our $first_half;
our $second_half;

while (<>) {
    s{\R\z}{};
    $_ = expand($_);
    if ($half_height) {
        if ($half_width) {
            if (!defined $first_half) {
                $first_half = $_;
            } else {
                $second_half = $_;
                my $line_1 = $first_half;
                my $line_2 = $second_half;
                $line_1 .= " " if length($line_1) % 2 == 1;
                $line_2 .= " " if length($line_2) % 2 == 1;
                while (length($line_1) < length($line_2)) {
                    $line_1 .= " ";
                }
                while (length($line_2) < length($line_1)) {
                    $line_2 .= " ";
                }
                my $line = "";
                for (my $i = 0; $i < length($line_1); $i += 2) {
                    my $top = substr($line_1, $i, 2);
                    my $bot = substr($line_2, $i, 2);
                    $line .= replace($top . $bot, @HALF_WIDTH_HALF_HEIGHT);
                }
                undef $second_half;
                undef $first_half;
                print($line, "\n");
            }
        } else {                # half height, full width
            if (!defined $first_half) {
                $first_half = $_;
            } else {
                $second_half = $_;
                my $line_1 = $first_half;
                my $line_2 = $second_half;
                $line_1 .= " " if length($line_1) % 2 == 1;
                $line_2 .= " " if length($line_2) % 2 == 1;
                while (length($line_1) < length($line_2)) {
                    $line_1 .= " ";
                }
                while (length($line_2) < length($line_1)) {
                    $line_2 .= " ";
                }
                my $line = "";
                for (my $i = 0; $i < length($line_1); $i++) {
                    my $top = substr($line_1, $i, 1);
                    my $bot = substr($line_2, $i, 1);
                    if (!defined $top || $top eq "") {
                        $top = " ";
                    }
                    if (!defined $bot || $bot eq "") {
                        $bot = " ";
                    }
                    if ($ascii) {
                        $line .= replace($top . $bot, @ASCII_HALF_HEIGHT);
                    } else {
                        $line .= replace($top . $bot, @HALF_HEIGHT);
                    }
                }
                undef $second_half;
                undef $first_half;
                print($line, "\n");
            }
        }
    } else {
        if ($half_width) {      # full height, half width
            $_ .= " " if length($_) % 2 == 1;
            my $line = "";
            for (my $i = 0; $i < length($_); $i += 2) {
                my $substr = substr($_, $i, 2);
                $line .= replace($substr, @HALF_WIDTH);
            }
            print($line, "\n");
        } else {                # full size
            if ($ascii) {
                s{.}{replace($&, @ASCII_FULL_SIZE)}ge;
            } else {
                s{.}{replace($&, @FULL_SIZE)}ge;
            }
            print($_, "\n");
        }
    }
}

sub replace {
    my ($str, @pairs) = @_;
    while (scalar @pairs >= 2) {
        my ($rx, $value) = splice(@pairs, 0, 2);
        if (ref $rx eq "") {
            if ($str eq $rx) {
                return $value;
            }
        } elsif (ref $rx eq "Regexp") {
            if ($str =~ qr{^${rx}$}) {
                return $value;
            }
        }
    }
    return " ";
}
