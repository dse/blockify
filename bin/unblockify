#!/usr/bin/perl
use warnings;
use strict;
use open IO => ":utf8";
use Text::Tabs qw(expand);
use List::Util qw(max);

our $half_height;
our $half_width;

use Getopt::Long;
Getopt::Long::Configure(qw(gnu_getopt));
Getopt::Long::GetOptions(
    "h|half|half-height" => \$half_height,
    # "w|half-width" => \$half_width,
);

while (<>) {
    s{\R\z}{};
    $_ = expand($_);
    if ($half_height) {
        my $line_1 = "";
        my $line_2 = "";
        for (my $i = 0; $i < length($_); $i++) {
            my $chr = substr($_, $i, 1);
            if ($chr eq "▄" || $chr eq "," || $chr eq ".") {
                $line_1 .= " ";
                $line_2 .= "#";
            } elsif ($chr eq "▀" || $chr eq "'" || $chr eq "`" || $chr eq '"') {
                $line_1 .= "#";
                $line_2 .= " ";
            } elsif ($chr ne " " && $chr ne "\xa0") {
                $line_1 .= "#";
                $line_2 .= "#";
            } else {
                $line_1 .= " ";
                $line_2 .= " ";
            }
        }
        print($line_1, "\n", $line_2, "\n");
    } else {
        s{▄}{.}g;
        s{█}{:}g;
        s{▀}{'}g;
        print($_, "\n");
    }
}
