#!/usr/bin/perl
use utf8;
use warnings;
use strict;
use open IO => ":utf8";
use Text::Tabs qw(expand);
use List::Util qw(max);

binmode(STDIN, ":utf8");
binmode(STDOUT, ":utf8");
binmode(STDERR, ":utf8");

our $half_height;
our $half_width;

use Getopt::Long;
Getopt::Long::Configure(qw(gnu_getopt));
Getopt::Long::GetOptions(
    "h|half|half-height" => \$half_height,
    "w|half-width" => \$half_width,
);

our $RX_SPACE      = qr{\s};
our $RX_UPPER_HALF = qr{['"`▀]};
our $RX_LOWER_HALF = qr{[,.▄]};
our $RX_FULL       = qr{[^\s'"`,.▀▄]};

our @HALF_WIDTH_HALF_HEIGHT = (
    " "            => ["  ", "  "],
    "▗"            => ["  ", " #"],
    "▖"            => ["  ", "# "],
    "▄"            => ["  ", "##"],
    "▝"            => [" #", "  "],
    "▐"            => [" #", " #"],
    "▞"            => [" #", "# "],
    "▟"            => [" #", "##"],
    "▘"            => ["# ", "  "],
    "▚"            => ["# ", " #"],
    "▌"            => ["# ", "# "],
    "▙"            => ["# ", "##"],
    "▀"            => ["##", "  "],
    "▜"            => ["##", " #"],
    "▛"            => ["##", "# "],
    "█"            => ["##", "##"],
    $RX_SPACE      => ["  ", "  "],
    $RX_LOWER_HALF => ["  ", "##"],
    $RX_UPPER_HALF => ["##", "  "],
    $RX_FULL       => ["##", "##"],
);

our @HALF_WIDTH = (
    " "            => "  ",
    "▗"            => " .",
    "▖"            => ". ",
    "▄"            => "..",
    "▝"            => " '",
    "▐"            => " :",
    "▞"            => ".'",
    "▟"            => ".:",
    "▘"            => "' ",
    "▚"            => "'.",
    "▌"            => ": ",
    "▙"            => ":.",
    "▀"            => "''",
    "▜"            => "':",
    "▛"            => ":'",
    "█"            => "::",
    $RX_SPACE      => "  ",
    $RX_LOWER_HALF => "..",
    $RX_UPPER_HALF => "''",
    $RX_FULL       => "::",
);

our @HALF_HEIGHT = (
    " "            => [" ", " "],
    "▄"            => [" ", "#"],
    "▀"            => ["#", " "],
    "█"            => ["#", "#"],
    $RX_SPACE      => [" ", " "],
    $RX_LOWER_HALF => [" ", "#"],
    $RX_UPPER_HALF => ["#", " "],
    $RX_FULL       => ["#", "#"],
);

our @FULL_SIZE = (
    " "            => " ",
    "▄"            => ".",
    "▀"            => "'",
    "█"            => ":",
    $RX_SPACE      => " ",
    $RX_LOWER_HALF => ".",
    $RX_UPPER_HALF => "'",
    $RX_FULL       => ":",
);

while (<>) {
    s{\R\z}{};
    $_ = expand($_);
    if ($half_height) {
        if ($half_width) {
            my $line_1 = "";
            my $line_2 = "";
            for (my $i = 0; $i < length($_); $i++) {
                my $value = replace(substr($_, $i, 1), @HALF_WIDTH_HALF_HEIGHT);
                $line_1 .= $value->[0];
                $line_2 .= $value->[1];
            }
            if ($line_1 =~ m{^[ :]+$}) {
                s{:}{#}g;
            }
            print($line_1, "\n", $line_2, "\n");
        } else {
            my $line_1 = "";
            my $line_2 = "";
            for (my $i = 0; $i < length($_); $i++) {
                my $value = replace(substr($_, $i, 1), @HALF_HEIGHT);
                $line_1 .= $value->[0];
                $line_2 .= $value->[1];
            }
            if ($line_1 =~ m{^[ :]+$}) {
                s{:}{#}g;
            }
            print($line_1, "\n", $line_2, "\n");
        }
    } else {
        if ($half_width) {
            s{.}{replace($&, @HALF_WIDTH)}ge;
            if ($_ =~ m{^[ :]+$}) {
                s{:}{#}g;
            }
            print($_, "\n");
        } else {
            s{.}{replace($&, @FULL_SIZE)}ge;
            if ($_ =~ m{^[ :]+$}) {
                s{:}{#}g;
            }
            print($_, "\n");
        }
    }
}

sub replace {
    my ($str, @pairs) = @_;
    while (scalar @pairs >= 2) {
        my ($rx, $value) = splice(@pairs, 0, 2);
        if (ref $rx eq "") {
            if ($str eq $rx) {
                return $value;
            }
        } elsif (ref $rx eq "Regexp") {
            if ($str =~ qr{^${rx}$}) {
                return $value;
            }
        }
    }
    return " ";
}
